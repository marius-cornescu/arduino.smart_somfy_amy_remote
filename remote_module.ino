void remote_Setup() {
  debugPrintln(F("REMOTE:Setup >>>"));
  //..............................
  pinMode(SOUND_SENSOR_PIN, INPUT);  // Set the sound signal pin as input
  analogSetPinAttenuation(SOUND_SENSOR_PIN, ADC_11db);
  //..............................
  delay(1 * TIME_TICK);
  debugPrintln(F("REMOTE:Setup <<<"));
}
